---
import { Icon } from "astro-icon/components";

---

<style>
    .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 1000;
        overflow: auto;
    }

    .modal-content {
        background-color: white;
        margin: 10% auto;
        padding: 20px;
        border-radius: 8px;
        max-width: 425px;
        width: 90%;
        position: relative;
    }

    .close {
        position: absolute;
        right: 20px;
        top: 15px;
        font-size: 24px;
        cursor: pointer;
    }

    .collapsible-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out;
    }

    .collapsible-content.open {
        max-height: 500px;
    }

    .rotate-icon {
        transform: rotate(180deg);
        transition: transform 0.3s ease;
    }
</style>

<div class="min-h-screen flex flex-col">
    <footer class="bg-black text-white w-full py-12 px-4 md:px-8">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-10">
            <!-- Left Column - About & Info -->
            <div class="space-y-6">
                <div class="w-full">
                    <button
                        class="collapsible-trigger flex items-center justify-between w-full border-b border-gray-800 pb-2"
                        data-target="about-content"
                    >
                        <h3 class="text-xl font-medium">About</h3>
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="chevron-icon"
                        >
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </button>
                    <div
                        id="about-content"
                        class="collapsible-content pt-4 space-y-3"
                    >
                        <a href="/our-story" class="block hover:text-gray-300"
                            >Our Story</a
                        >
                        <a href="/shade-match" class="block hover:text-gray-300"
                            >Shade Match Quiz</a
                        >
                        <a href="/press" class="block hover:text-gray-300"
                            >Press</a
                        >
                        <a href="/rewards" class="block hover:text-gray-300"
                            >Rewards</a
                        >
                        <a href="/join-team" class="block hover:text-gray-300"
                            >Join Our Team</a
                        >
                        <a
                            href="/privacy-policy"
                            class="block hover:text-gray-300">Privacy Policy</a
                        >
                        <a
                            href="/refund-policy"
                            class="block hover:text-gray-300">Refund Policy</a
                        >
                    </div>
                </div>

                <div class="w-full">
                    <button
                        class="collapsible-trigger flex items-center justify-between w-full border-b border-gray-800 pb-2"
                        data-target="store-content"
                    >
                        <h3 class="text-xl font-medium">The Store</h3>
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="chevron-icon"
                        >
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </button>
                    <div
                        id="store-content"
                        class="collapsible-content pt-4 space-y-3"
                    >
                        <a href="/tutorials" class="block hover:text-gray-300"
                            >Tutorials</a
                        >
                        <a href="/articles" class="block hover:text-gray-300"
                            >Articles</a
                        >
                        <a href="/inspiration" class="block hover:text-gray-300"
                            >Celebrity Inspo</a
                        >
                        <a href="/features" class="block hover:text-gray-300"
                            >Featured Products</a
                        >
                    </div>
                </div>
            </div>

            <!-- Middle Column - Login & Social -->
            <div class="space-y-8">
                <div class="space-y-4">
                    <button
                        id="login-button"
                        class="text-white p-0 h-auto hover:text-gray-300 cursor-pointer"
                    >
                        Register / Login
                    </button>

                    <div class="flex items-center space-x-2">
                        <Icon name="localizacion" />
                        <a href="/store-locator" class="hover:text-gray-300"
                            >Store Locator</a
                        >
                    </div>

                    <div class="flex items-center space-x-2">
                        <Icon name="contacto" />
                        <a href="/contact" class="hover:text-gray-300"
                            >Contact Us</a
                        >
                    </div>
                </div>

                <div class="flex space-x-4">
                    <a href="https://facebook.com" class="hover:text-gray-300">
                        <Icon name="facebook" size={30} />
                        <span class="sr-only">Facebook</span>
                    </a>
                    <a href="https://twitter.com" class="hover:text-gray-300">
                        <Icon name="twitter" size={30} />
                        <span class="sr-only">Twitter</span>
                    </a>
                    <a href="https://instagram.com" class="hover:text-gray-300">
                        <Icon name="instagram" size={30} />
                        <span class="sr-only">Instagram</span>
                    </a>
                    <a href="https://tiktok.com" class="hover:text-gray-300">
                        <Icon name="tiktok" size={30} />
                        <span class="sr-only">TikTok</span>
                    </a>
                    <a href="https://youtube.com" class="hover:text-gray-300">
                        <Icon name="youtube" size={30} />
                        <span class="sr-only">YouTube</span>
                    </a>
                </div>
            </div>

            <!-- Right Column - Newsletter & Certifications -->
            <div class="space-y-6">
                <div>
                    <h3 class="text-xl font-medium mb-2">
                        Let's stay connected
                    </h3>
                    <p class="text-sm mb-4">
                        Regístrate para recibir ofertas exclusivas y
                        actualizaciones sobre todo lo relacionado con la tienda.
                    </p>

                    <div class="space-y-3">
                        <div>
                            <label for="footer-email" class="sr-only"
                                >Email address</label
                            >
                            <input
                                id="footer-email"
                                type="email"
                                placeholder="Email address"
                                class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-600"
                            />
                        </div>
                        <div>
                            <label for="footer-phone" class="sr-only"
                                >Telefono</label
                            >
                            <input
                                id="footer-phone"
                                type="tel"
                                placeholder="Phone"
                                class="w-full px-3 py-2 bg-gray-900 border border-gray-700 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-600"
                            />
                        </div>
                        <button
                            id="subscribe-button"
                            class="w-full bg-white text-black font-medium py-2 px-4 rounded-md hover:bg-gray-200 transition-colors"
                        >
                            Subscribete
                        </button>
                    </div>

                    <p class="text-xs mt-4 text-gray-400">
                        Al enviar este formulario, acepta recibir mensajes de
                        texto promocionales y de marketing personalizados de
                        forma recurrente. El consentimiento no es condición para
                        realizar ninguna compra. Responda "AYUDA" para obtener
                        ayuda y "PARAR" para cancelar. La frecuencia de los
                        mensajes varía. Pueden aplicarse tarifas por mensajes y
                        datos. Consulte los Términos y la Política de
                        Privacidad.
                    </p>
                </div>

                <div class="flex justify-between">
                    <div class="text-center">
                        <div
                            class="h-16 w-16 rounded-full bg-gray-300 flex items-center justify-center mx-auto mb-2"
                        >
                            <span class="text-black font-bold text-xs"
                                >Vegan</span
                            >
                        </div>
                        <span class="text-xs">Vegan</span>
                    </div>
                    <div class="text-center">
                        <div
                            class="h-16 w-16 rounded-full bg-gray-300 flex items-center justify-center mx-auto mb-2"
                        >
                            <span class="text-black font-bold text-xs"
                                >Cruelty-free</span
                            >
                        </div>
                        <span class="text-xs">Cruelty-free</span>
                    </div>
                    <div class="text-center">
                        <div
                            class="h-16 w-16 rounded-full bg-gray-300 flex items-center justify-center mx-auto mb-2"
                        >
                            <span class="text-black font-bold text-xs"
                                >Paraben-free</span
                            >
                        </div>
                        <span class="text-xs">Paraben-free</span>
                    </div>
                </div>
            </div>
        </div>

        <div
            class="max-w-7xl mx-auto mt-12 pt-6 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center"
        >
            <p class="text-sm text-gray-400">
                Copyright © <span id="current-year"></span>, Grupo Nomada 2.
            </p>
        </div>
    </footer>
    <!-- Login Modal -->
    <div id="login-modal" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <h2 class="text-xl font-bold mb-2">Login to your account</h2>
            <p class="text-gray-600 mb-4">
                Enter your credentials to access your account
            </p>

            <div class="space-y-4">
                <div>
                    <label
                        for="login-email"
                        class="block text-sm font-medium text-gray-700 mb-1"
                        >Email</label
                    >
                    <input
                        id="login-email"
                        type="email"
                        placeholder="your@email.com"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-400"
                    />
                </div>
                <div>
                    <label
                        for="login-password"
                        class="block text-sm font-medium text-gray-700 mb-1"
                        >Password</label
                    >
                    <input
                        id="login-password"
                        type="password"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-400"
                    />
                </div>
                <button
                    class="w-full bg-black text-white font-medium py-2 px-4 rounded-md hover:bg-gray-800 transition-colors"
                >
                    Login
                </button>
                <div class="text-center text-sm">
                    Don't have an account?
                    <button
                        id="register-link"
                        class="text-blue-600 hover:underline">Register</button
                    >
                </div>
            </div>
        </div>
    </div>

    <!-- Register Modal -->
    <div id="register-modal" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <h2 class="text-xl font-bold mb-2">Create an account</h2>
            <p class="text-gray-600 mb-4">
                Fill in your details to create a new account
            </p>

            <div class="space-y-4">
                <div>
                    <label
                        for="register-name"
                        class="block text-sm font-medium text-gray-700 mb-1"
                        >Full Name</label
                    >
                    <input
                        id="register-name"
                        type="text"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-400"
                    />
                </div>
                <div>
                    <label
                        for="register-email"
                        class="block text-sm font-medium text-gray-700 mb-1"
                        >Email</label
                    >
                    <input
                        id="register-email"
                        type="email"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-400"
                    />
                </div>
                <div>
                    <label
                        for="register-password"
                        class="block text-sm font-medium text-gray-700 mb-1"
                        >Password</label
                    >
                    <input
                        id="register-password"
                        type="password"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-400"
                    />
                </div>
                <div>
                    <label
                        for="register-confirm"
                        class="block text-sm font-medium text-gray-700 mb-1"
                        >Confirm Password</label
                    >
                    <input
                        id="register-confirm"
                        type="password"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-gray-400"
                    />
                </div>
                <button
                    class="w-full bg-black text-white font-medium py-2 px-4 rounded-md hover:bg-gray-800 transition-colors"
                >
                    Register
                </button>
                <div class="text-center text-sm">
                    Already have an account?
                    <button
                        id="login-link"
                        class="text-blue-600 hover:underline">Login</button
                    >
                </div>
            </div>
        </div>
    </div>
</div>

<script type="module">
    // Set current year in copyright
    document.getElementById("current-year").textContent =
        new Date().getFullYear();

    // Collapsible sections
    document.querySelectorAll(".collapsible-trigger").forEach((trigger) => {
        trigger.addEventListener("click", function () {
            const targetId = this.getAttribute("data-target");
            const content = document.getElementById(targetId);
            content.classList.toggle("open");

            // Toggle chevron icon rotation
            const icon = this.querySelector(".chevron-icon");
            icon.classList.toggle("rotate-icon");
        });
    });

    // Modal functionality
    const loginModal = document.getElementById("login-modal");
    const registerModal = document.getElementById("register-modal");
    const loginButton = document.getElementById("login-button");
    const registerLink = document.getElementById("register-link");
    const loginLink = document.getElementById("login-link");
    const closeButtons = document.querySelectorAll(".close");

    // Open login modal
    loginButton.addEventListener("click", function () {
        loginModal.style.display = "block";
    });

    // Switch to register modal
    registerLink.addEventListener("click", function () {
        loginModal.style.display = "none";
        registerModal.style.display = "block";
    });

    // Switch to login modal
    loginLink.addEventListener("click", function () {
        registerModal.style.display = "none";
        loginModal.style.display = "block";
    });

    // Close modals with X button
    closeButtons.forEach((button) => {
        button.addEventListener("click", function () {
            loginModal.style.display = "none";
            registerModal.style.display = "none";
        });
    });

    // Close modals when clicking outside
    window.addEventListener("click", function (event) {
        if (event.target === loginModal) {
            loginModal.style.display = "none";
        }
        if (event.target === registerModal) {
            registerModal.style.display = "none";
        }
    });

    // Newsletter subscription
    const subscribeButton = document.getElementById("subscribe-button");
    subscribeButton.addEventListener("click", function () {
        const email = document.getElementById("footer-email").value;
        const phone = document.getElementById("footer-phone").value;

        if (email && phone) {
            alert(
                "¡Gracias por suscribirte! Te mantendremos informado sobre nuestras ofertas.",
            );
            document.getElementById("footer-email").value = "";
            document.getElementById("footer-phone").value = "";
        } else {
            alert("Por favor, completa todos los campos para suscribirte.");
        }
    });
</script>
