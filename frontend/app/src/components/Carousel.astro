---
// src/components/Carousel.astro
import { Icon } from "astro-icon/components";

// Usamos Astro.glob con la ruta relativa a la raíz pública
const images = await Astro.glob('../assets/images/carousel/*.jpg');

---

<div class="relative overflow-hidden max-w-6xl mx-auto" data-carousel>
  <div class="flex transition-transform duration-500 ease-in-out" data-carousel-track>
    {images.map((image) => (
      <img
        src={image.default.src}
        class="min-w-full h-auto sm:h-[300px] md:h-[400px] object-contain shrink-0"
        alt="Imagen del carrusel"
        loading="lazy"
      />
    ))}
  </div>
  <button
    class="absolute top-1/2 left-4 -translate-y-1/2 text-black z-10"    
    data-carousel-prev
  >
    <Icon name="prev" size={50} />
  </button>
  <button
    class="absolute top-1/2 right-4 -translate-y-1/2 text-black z-10"
    data-carousel-next
  >
    <Icon name="next" size={50} />
  </button>
</div>

<script src="/scripts/carousel.js" defer></script>
