---
// ProductCard.astro
import { Icon } from "astro-icon/components";
const {
    href = "#",
    imageUrl,
    imageAlt = "",
    price,
    oldPrice,
    title,
    description,
} = Astro.props;
---

<a
    href={href}
    class="group relative block w-full sm:max-w-[300px] min-h-[520px] overflow-hidden"
>
    <button
        class="absolute end-4 top-4 z-3 rounded-full bg-white p-1.5 text-gray-900 transition hover:text-gray-900/75"
    >
        <span class="sr-only">Wishlist</span>
        <Icon name="corazon" size={20} />
    </button>

    <img
        src={imageUrl}
        alt={imageAlt}
        class="h-64 w-full object-center transition duration-500 group-hover:scale-105 sm:h-72"
    />
    <!-- <img
    src={imageUrl}
    alt={imageAlt}
    class="h-auto w-auto object-contain transition duration-500 group-hover:scale-105 sm:h-72 sm:w-auto"
/> -->

    <div class="relative border border-gray-100 p-6">
        <p class="text-gray-700">
            {price}
            <span class="text-gray-400 line-through">{oldPrice}</span>
        </p>

        <h3 class="mt-1.5 text-lg font-medium text-gray-900">{title}</h3>

        <p class="mt-1.5 line-clamp-3 text-gray-700">{description}</p>

        <form class="mt-4 flex gap-4">
            <button
                class="block w-full rounded-l bg-gray-200 px-4 py-3 text-sm font-medium text-gray-900 transition hover:scale-105"
            >
                Add to Cart
            </button>
            <button
                type="button"
                class="block w-full rounded-sm bg-gray-900 px-4 py-3 text-sm font-medium text-white transition hover:scale-105"
            >
                Buy Now
            </button>
        </form>
    </div>
</a>
