---
// ProductCard.astro
const { name, image, price, link } = Astro.props;
---

<div class="border p-4 rounded-lg shadow-lg max-w-xs mx-auto">
    <img src={image} alt={name} class="w-full h-48 object-cover rounded-t-lg" />
    <h3 class="text-xl font-semibold mt-2">{name}</h3>
    <p class="text-gray-600">${price}</p>
    <a href={link} class="text-blue-500 hover:underline">View Product</a>
</div>
