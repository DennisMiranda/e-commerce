<!--Resumen de compra -->
<div class="container mx-auto p-4 max-w-2xl">
  <h1 class="text-2xl font-bold mb-6 text-center">Resumen de compra</h1>

  <div id="cart-content" class="space-y-4">
    <p class="text-center text-gray-500">Cargando productos...</p>
  </div>

  <div id="cart-summary" class="mt-6 hidden">
    <div class="text-right font-bold text-lg mb-4">
      Subtotal: <span id="cart-subtotal">S/. 0.00</span>
    </div>
  </div>
</div>

<script type="module">
  document.addEventListener("DOMContentLoaded", () => {
    const cartContent = document.getElementById("cart-content");
    const cartSummary = document.getElementById("cart-summary");
    const subtotalElement = document.getElementById("cart-subtotal");
    const checkoutButton = document.getElementById("checkout-button");

    const cart = JSON.parse(localStorage.getItem("cart")) || {}; // Obtener carrito desde localStorage
    const productData = JSON.parse(localStorage.getItem("productData")) || {}; // Obtener datos de productos desde localStorage

    // Crear productos a partir del carrito
    const products = Object.entries(cart).map(([id, qty]) => {
      const data = productData[id] || {};
      return {
        id: parseInt(id),
        qty,
        name: data.name,
        price: data.price,
        image: data.image,
      };
    });

    // Renderizar el carrito
    function renderCart() {
      cartContent.innerHTML = "";

      if (products.length === 0) {
        cartContent.innerHTML =
          '<p class="text-center text-gray-700">Your cart is empty.</p>';
        cartSummary.classList.add("hidden");
      } else {
        let currentSubtotal = 0;
        products.forEach((item) => {
          // Validar que los valores de price y qty sean números válidos
          const price = parseFloat(item.price) || 0;
          const qty = parseInt(item.qty) || 0;

          // Generar el HTML para cada producto
          const itemElement = document.createElement("div");
          itemElement.className = "border-b pb-4 flex gap-4 items-center";
          itemElement.innerHTML = `
            <img src="${item.image}" alt="${item.name}" class="w-20 h-20 object-cover rounded">
            <div class="flex-1">
              <p class="font-semibold">${item.name}</p>
              <p class="text-sm text-gray-600">S/. ${price.toFixed(2)}</p>  <!-- Asegurar que 'price' es un número válido -->
              <div class="flex items-center mt-2">
                <button data-id="${item.id}" data-change="-1" class="qty-change px-2 py-1 border rounded text-gray-700 hover:bg-gray-100"> − </button>
                <span class="px-3 font-medium">${qty}</span>  <!-- Asegurar que 'qty' es un número válido -->
                <button data-id="${item.id}" data-change="1" class="qty-change px-2 py-1 border rounded text-gray-700 hover:bg-gray-100"> + </button>
                <button data-id="${item.id}" class="remove-item text-red-500 hover:text-red-700 ml-4 text-sm">Remove</button>
              </div>
            </div>
             <div class="text-right font-semibold">
                 S/. ${(price * qty).toFixed(2)}  <!-- Validar que el precio y la cantidad son números válidos -->
             </div>
          `;
          cartContent.appendChild(itemElement);
          currentSubtotal += price * qty;
        });

        subtotalElement.textContent = `S/. ${currentSubtotal.toFixed(2)}`;
        cartSummary.classList.remove("hidden");
      }

      addEventListeners();
    }

    function addEventListeners() {
      document.querySelectorAll(".qty-change").forEach((button) => {
        button.replaceWith(button.cloneNode(true));
      });
      document.querySelectorAll(".qty-change").forEach((button) => {
        button.addEventListener("click", () => {
          const id = parseInt(button.dataset.id);
          const change = parseInt(button.dataset.change);
          updateQuantity(id, change);
        });
      });

      document.querySelectorAll(".remove-item").forEach((button) => {
        button.replaceWith(button.cloneNode(true));
      });
      document.querySelectorAll(".remove-item").forEach((button) => {
        button.addEventListener("click", () => {
          const id = parseInt(button.dataset.id);
          removeItem(id);
        });
      });
    }

    function updateQuantity(productId, change) {
      const productIndex = products.findIndex((p) => p.id === productId);
      if (productIndex > -1) {
        products[productIndex].qty += change;
        if (products[productIndex].qty <= 0) {
          products.splice(productIndex, 1); // Eliminar el producto si qty es 0 o menor
        }
        saveCartAndRender();
      }
    }

    // Eliminar un producto del carrito
    function removeItem(productId) {
      // Validar que el producto exista antes de eliminarlo
      products = products.filter((p) => p.id !== productId);
      saveCartAndRender();
    }

    // Guardar carrito y renderizar
    function saveCartAndRender() {
      const cartObj = {};
      products.forEach((p) => {
        cartObj[p.id] = p.qty;
      });
      localStorage.setItem("cart", JSON.stringify(cartObj));
      renderCart();
    }

    renderCart();
  });
</script>
