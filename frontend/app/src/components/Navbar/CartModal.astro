---
import { Icon } from "astro-icon/components";
---

<!-- Overlay -->
<div
    id="cartModalOverlay"
    class="fixed inset-0 bg-black opacity-50 z-40 hidden"
    onclick="window.closeCartModal()"
>
</div>

<!-- Modal -->
<div
    id="cartModal"
    class="fixed top-0 right-0 h-full w-80 bg-white shadow-lg z-50 transform translate-x-full transition-transform duration-300 overflow-y-auto"
>
    <div class="p-4 relative">
        <button
            onclick="window.closeCartModal()"
            class="absolute top-2 right-2 p-2 text-gray-700 hover:text-gray-900"
        >
            <Icon name="cerrar" size={30} />
        </button>
        <h2 class="text-xl font-bold mb-4">Cart</h2>
        <div id="cartContent" class="space-y-4 text-sm text-gray-800"></div>
    </div>
</div>

<!-- Toast -->
<div
    id="toast"
    class="fixed bottom-4 right-4 bg-black text-white px-4 py-2 rounded hidden z-50 text-sm"
>
</div>

<script type="module">
    function renderCart() {
        const cart = JSON.parse(localStorage.getItem("cart") || "{}");
        const productData = JSON.parse(
            localStorage.getItem("productData") || "{}",
        );
        const content = document.getElementById("cartContent");
        content.innerHTML = "";

        const ids = Object.keys(cart);
        if (ids.length === 0) {
            content.innerHTML =
                "<p class='text-center'>No hay productos en el carrito.</p>";
            return;
        }

        let subtotal = 0;

        ids.forEach((id) => {
            const qty = cart[id];
            const data = productData[id];
            if (!data) return;

            const total = qty * data.price;
            subtotal += total;

            const item = document.createElement("div");
            item.className = "border-b pb-4 flex gap-4";
            item.innerHTML = `
                <img src="${data.image}" alt="${data.name}" class="w-16 h-16 object-cover" />
                <div class="flex-1">
                    <p class="font-semibold">${data.name}</p>
                    <p class="text-sm text-gray-600">$${data.price}</p>
                    <div class="flex items-center mt-1 gap-1">
                        <button class="px-2 border" data-id="${id}" data-change="-1">−</button>
                        <span class="px-2">${qty}</span>
                        <button class="px-2 border" data-id="${id}" data-change="1">+</button>
                    </div>
                    <button class="text-red-500 text-xs mt-1" data-id="${id}" data-delete="true">Eliminar</button>
                </div>
            `;
            content.appendChild(item);
        });

        const totalDiv = document.createElement("div");
        totalDiv.className = "text-right font-bold text-lg";
        totalDiv.textContent = `Subtotal: $${subtotal.toFixed(2)}`;
        content.appendChild(totalDiv);

        const btnCart = document.createElement("button");
        btnCart.className = "w-full border p-2 bg-white hover:bg-gray-100 mt-4";
        btnCart.textContent = "GO TO CART";
        btnCart.onclick = () => (window.location.href = "/cart");
        content.appendChild(btnCart);

        const btnCheckout = document.createElement("button");
        btnCheckout.className =
            "w-full bg-black text-white p-2 hover:bg-gray-800";
        btnCheckout.textContent = "CHECKOUT";
        btnCheckout.onclick = () => (window.location.href = "/pagos");
        content.appendChild(btnCheckout);
    }

    function showToast(message) {
        const toast = document.getElementById("toast");
        toast.textContent = message;
        toast.classList.remove("hidden");
        setTimeout(() => toast.classList.add("hidden"), 2000);
    }

    function updateQty(id, change) {
        const cart = JSON.parse(localStorage.getItem("cart") || "{}");
        if (!cart[id]) return;

        cart[id] += change;
        if (cart[id] <= 0) delete cart[id];

        localStorage.setItem("cart", JSON.stringify(cart));
        renderCart();
        showToast("Cantidad actualizada");
    }

    function deleteItem(id) {
        const cart = JSON.parse(localStorage.getItem("cart") || "{}");
        delete cart[id];
        localStorage.setItem("cart", JSON.stringify(cart));
        renderCart();
        showToast("Producto eliminado");
    }

    window.addEventListener("DOMContentLoaded", () => {
        window.openCartModal = () => {
            renderCart();
            document
                .getElementById("cartModal")
                ?.classList.remove("translate-x-full");
            document
                .getElementById("cartModalOverlay")
                ?.classList.remove("hidden");
        };
        window.closeCartModal = () => {
            document
                .getElementById("cartModal")
                ?.classList.add("translate-x-full");
            document
                .getElementById("cartModalOverlay")
                ?.classList.add("hidden");
        };

        document
            .getElementById("cartContent")
            ?.addEventListener("click", (e) => {
                const btn = e.target;
                if (btn.dataset.change) {
                    updateQty(btn.dataset.id, Number(btn.dataset.change));
                } else if (btn.dataset.delete) {
                    deleteItem(btn.dataset.id);
                }
            });
    });
</script>
