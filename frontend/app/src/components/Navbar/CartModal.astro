---
const products = [
    {
        id: 1,
        name: "Semi-Matte Duo",
        price: 28,
        qty: 2,
        image: "/img/lip.png",
        color: "Pretty in Pink",
    },
    {
        id: 2,
        name: "Lip Gloss",
        price: 15,
        qty: 4,
        image: "/img/gloss.png",
        color: "Mauve Over",
    },
];
---

<!-- Overlay para bloquear la interacción con la página -->
<div
    id="cartModalOverlay"
    class="fixed inset-0 bg-black opacity-50 z-40 hidden"
    onclick="window.closeCartModal()"
>
</div>

<!-- Modal -->
<div
    id="cartModal"
    class="fixed top-0 right-0 h-full w-80 bg-white shadow-lg z-50 transform translate-x-full transition-transform duration-300 overflow-y-auto"
>
    <div class="p-4 relative">
        <!-- Botón X de cierre -->
        <button
            onclick="window.closeCartModal()"
            class="absolute top-2 right-2 text-lg font-bold text-gray-700 hover:text-gray-900"
        >
            ×
        </button>
        <h2 class="text-xl font-bold mb-4">Cart</h2>

        {
            products.length === 0 ? (
                <p class="text-center text-gray-700">
                    No hay productos en el carrito.
                </p>
            ) : (
                <div class="space-y-4">
                    {products.map((item) => (
                        <div class="border-b pb-4 flex gap-4">
                            <img
                                src={item.image}
                                alt={item.name}
                                class="w-16 h-16 object-cover"
                            />
                            <div class="flex-1">
                                <p class="font-semibold">{item.name}</p>
                                <p class="text-sm text-gray-700">
                                    ${item.price}
                                </p>
                                <p class="text-sm">Color: {item.color}</p>
                                <div class="flex items-center mt-1">
                                    <button
                                        class="px-2 border"
                                        onclick={`updateQty(${item.id}, -1)`}
                                    >
                                        −
                                    </button>
                                    <span class="px-3">{item.qty}</span>
                                    <button
                                        class="px-2 border"
                                        onclick={`updateQty(${item.id}, 1)`}
                                    >
                                        +
                                    </button>
                                </div>
                            </div>
                        </div>
                    ))}
                    <div class="text-right font-bold text-lg">
                        Subtotal: $
                        {products
                            .reduce(
                                (acc, item) => acc + item.price * item.qty,
                                0,
                            )
                            .toFixed(2)}
                    </div>
                    <button
                        onclick="window.location.href='/cart'"
                        class="w-full border p-2 bg-white hover:bg-gray-100"
                    >
                        GO TO CART
                    </button>
                    <button
                        onclick="window.location.href='/pagos'"
                        class="w-full bg-black text-white p-2 hover:bg-gray-800"
                    >
                        CHECKOUT
                    </button>
                </div>
            )
        }
    </div>
</div>

<script type="module">
    window.addEventListener("DOMContentLoaded", () => {
        window.openCartModal = () => {
            // Mostrar el modal y el overlay
            document
                .getElementById("cartModal")
                ?.classList.remove("translate-x-full");
            document
                .getElementById("cartModalOverlay")
                ?.classList.remove("hidden");
        };

        window.closeCartModal = () => {
            // Ocultar el modal y el overlay
            document
                .getElementById("cartModal")
                ?.classList.add("translate-x-full");
            document
                .getElementById("cartModalOverlay")
                ?.classList.add("hidden");
        };
    });

    function updateQty(id, change) {
        alert("Actualizar cantidad en lógica real");
    }

    // Función para almacenar los productos en localStorage
    function storeCart() {
        localStorage.setItem("cart", JSON.stringify(products));
    }

    // Redirigir a la página de carrito y almacenar los productos
    function goToCart() {
        storeCart();
        window.location.href = "/cart";
    }

    // Redirigir a la página de checkout y almacenar los productos
    function goToCheckout() {
        storeCart();
        window.location.href = "/pagos";
    }
</script>
