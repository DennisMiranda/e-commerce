---
import ProductCard from "../components/ProductCard.astro";

const res = await fetch(`http://localhost:3000/app/products/top`);
const products = await res.json();
---

<!-- Top latest products -->
<div class="max-w-screen-xl mx-auto px-4 py-8">
  <div class="flex items-center my-6 justify-center">
    <h1 class="text-2xl font-bold text-center">Productos nuevos</h1>
  </div>

  <div
    class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-10 max-w-screen-xl mx-auto justify-center"
  >
    {
      products.map((product) => (
        <ProductCard
          href={`/producto/${product.id}`}
          imageUrl={product.image}
          price={`S/. ${product.price}`}
          title={product.name}
          description={product.description}
        />
      ))
    }
  </div>
</div>
