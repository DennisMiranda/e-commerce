---
import "./src/styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
	</head>
	<body>
    <header>
		<nav class="bg-[var(--color-aside-bg)] relative">
			<div class="max-w-screen-xl flex items-center justify-between mx-auto p-4">
			  <div class="flex items-center space-x-8 rtl:space-x-reverse relative">
				<a href="#" class="flex items-center space-x-3 rtl:space-x-reverse">
				  <span class="self-center text-2xl font-semibold whitespace-nowrap text-[var(--color-text-primary)]">E-Commerce</span>
				</a>

				<button id="dropdownNavbarLink" data-dropdown-toggle="dropdownNavbar" class="flex items-center justify-between py-2 px-3 bg-[var(--color-aside-bg)] rounded-sm text-[var(--color-text-primary)] dark:hover:bg-gray-700 relative">
          Categorías
        </button>
        
        <div id="dropdownNavbar" class="z-10 hidden absolute left-0 mt-50 w-max font-normal rounded-lg grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 bg-transparent">
          <ul class="py-2 text-sm">
            <li><a href="#" class="block px-4 py-2 bg-[var(--color-secondary)] text-[var(--color-text-primary)] hover:bg-[var(--color-aside-bg-hover)]">Cosméticos</a></li>
            <li><a href="#" class="block px-4 py-2 bg-[var(--color-secondary)] text-[var(--color-text-primary)] hover:bg-[var(--color-aside-bg-hover)]">Alimentos</a></li>
            <li><a href="#" class="block px-4 py-2 bg-[var(--color-secondary)] text-[var(--color-text-primary)] hover:bg-[var(--color-aside-bg-hover)]">Ropa</a></li>
          </ul>
        </div>
			  </div>
		  
			  
			  <div class="flex justify-center">
				<input type="text" placeholder="¿Que buscas hoy?" class="bg-[var(--color-text-primary)] p-2 rounded-full focus:outline-none focus:ring-2 focus:ring-blue-500 w-120" />
			  </div>
			  

			  <div class="flex space-x-4 rtl:space-x-reverse">
				<button class="flex flex-col items-center justify-center p-2 rounded-md bg-transparent  hover:text-blue-400 text-[var(--color-text-primary)]">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
						<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
					  </svg>

					<span class="">Carrito</span>
				  </button>
				  <div class="flex space-x-4 rtl:space-x-reverse">
					<button class="flex flex-col items-center justify-center p-2 rounded-md bg-transparent  hover:text-blue-400 text-[var(--color-text-primary)]">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
						  </svg>
						  
						<span class="">Cuenta</span>
					  </button>
			  </div>
			</div>
		  </nav>

      <script>
        document.addEventListener('DOMContentLoaded', function () {
          const dropdownButton = document.getElementById('dropdownNavbarLink');
          const dropdownMenu = document.getElementById('dropdownNavbar');
      
          if (dropdownButton && dropdownMenu) {
            dropdownButton.addEventListener('click', function () {
              // Alternar la visibilidad del menú
              dropdownMenu.classList.toggle('hidden');
              
              // Agregar la clase 'grid' solo cuando el dropdown está visible
              if (!dropdownMenu.classList.contains('hidden')) {
                dropdownMenu.classList.add('grid');
              } else {
                dropdownMenu.classList.remove('grid');
              }
            });
          }
        });
      </script>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
