---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import { Icon } from "astro-icon/components";
import ModalForm from "../components/ModalForm.astro";
import ButtonOrders from "../components/Navbar/ButtonOrders.astro";
import ButtonLogin from "../components/Navbar/ButtonLogin.astro";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://fonts.googleapis.com/css2?family=Cal+Sans&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
    <title>Ecommerce</title>
  </head>
  <body class="bg-white min-h-screen">
    <!-- Header principal -->
    <header class="bg-white pt-4 px-4 md:px-8">
      <!-- Búsqueda, nombre y botones principal -->
      <div class="mx-auto flex items-center justify-between">
        <!-- Búsqueda desktop -->
        <div
          class="w-1/3 hidden md:flex items-center justify-end rounded-full border border-border-primary relative"
        >
          <input
            id="search-input"
            type="text"
            placeholder="Buscar"
            class="flex-grow w-full focus:outline-none text-text-secondary placeholder-gray-700 p-2 pl-2"
          />
          <Icon name="busqueda" class="absolute mr-2 w-10 text-2xl" />
        </div>

        <!-- Logo (centro) -->
        <div class="w-1/3 flex md:justify-center">
          <a
            href="/"
            class="mented-logo text-3xl md:text-4xl font-light"
            style="font-family: 'Cal Sans', sans-serif;">Aroma</a
          >
        </div>

        <!-- Cuenta y carrito (derecha)-->
        <div class="w-1/3 flex justify-end gap-4">
          <!-- Búsqueda iconos mobile -->
          <button
            id="mobile-search-btn"
            class="md:hidden block p-2 focus:outline-none cursor-pointer"
          >
            <Icon name="busqueda" size={30} />
          </button>

          <ButtonLogin />
          <ButtonOrders />

          <!-- MODIFICACION DEL CARRITO -->
          <div class="relative group">
            <button
              onclick="window.openCartModal()"
              class="p-2 focus:outline-none"
            >
              <Icon name="cart" size={30} />
              <span id="cart-count" class="cart-count">0</span>
            </button>
          </div>
        </div>
      </div>
    </header>
    <ModalForm />
    <main class="flex-grow w-full mx-0 max-w-none">
      <slot />
    </main>

    <!-- Footer como componente -->
    <Footer />
  </body>
</html>
