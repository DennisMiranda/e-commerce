---
import Layout from "../layouts/Layout.astro";

---

<Layout>
    <section class="max-w-5xl mx-auto p-6">
        <h2 class="text-2xl text-pink-800 font-bold mb-6">Tu carrito</h1>
    
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="md:col-span-2 space-y-4">
            <!-- Producto del carrito -->
            <div id="cart-item" class="flex gap-4 items-center border-b pb-4">
              <img src="/images/producto1.webp" alt="Producto" class="w-20 h-40 object-cover rounded-t-lg" />
              <div class="flex-1">
                <h2 class="font-semibold text-lg">Burberry Her Eau de Parfum</h2>
                <p class="text-sm text-gray-600">Volumen: 30 ML</p>
                <div class="flex items-center gap-2 mt-2">
                  <button id="decrease" class="px-2 py-1 font-bold border rounded hover:bg-pink-700 hover:text-white cursor-pointer">-</button>
                  <span id="cantidad">1</span>
                  <button id="increase" class="px-2 py-1 font-bold border rounded hover:bg-pink-700 hover:text-white  cursor-pointer">+</button>
                </div>
                <div id="quitarProducto" class="text-red-500 text-sm mt-2 cursor-pointer">Quitar artículo</div>
              </div>
              <div class="text-right font-semibold text-lg">S/30.00</div>
            </div>
          </div>
    
          <div class="bg-gray-100 p-6 rounded-lg">
            <h2 class="text-lg font-semibold mb-4">Resumen</h2>
            <div class="flex justify-between border-b pb-2 mb-2">
              <span>Subtotal</span>
              <span id="subtotal">S/30,00</span>
            </div>
            <div class="flex justify-between border-b pb-2 mb-2">
              <span >Impuesto (18%)</span>
              <span id="impuesto">S/5.40 </span>
            </div>
            <div class="flex justify-between font-bold text-lg">
              <span >Total</span>
              <span id="total">S/35.40 </span>
            </div>
    
            <div class="mt-4">
              <input type="text" placeholder="Código de descuento" class="w-full px-3 py-2 rounded border mb-2" />
              <button class="w-full bg-black text-white py-2 rounded hover:bg-pink-800">Tramitar pedido</button>
            </div>
          </div>
        </div>
      </section>

    <script is:inline>
        
        let cantidad = 1;
        const precioUnitario = 30.00;
        const maxCantidad = 4;

        const btnIncrease = document.getElementById("increase");
        const btnDecrease = document.getElementById("decrease");
        const btnQuitar = document.getElementById("quitarProducto");

        function updatePrecios() {
            const subtotal = cantidad * precioUnitario;
            const impuesto = subtotal * 0.18;
            const total = subtotal + impuesto;

            document.getElementById("cantidad").innerText = cantidad;
            document.getElementById("subtotal").innerText = `S/${subtotal.toFixed(2)}`;
            document.getElementById("impuesto").innerText = `S/${impuesto.toFixed(2)}`;
            document.getElementById("total").innerText = `S/${total.toFixed(2)}`;
        }

        function increase() {
            if (cantidad < maxCantidad) {
            cantidad++;
            updatePrecios();
            }
        }

        function decrease() {
            if (cantidad > 1) {
            cantidad--;
            updatePrecios();
            }
        }

        function quitarProducto() {
            const item = document.getElementById("cart-item");
            const contenedorResumen = item.parentElement.parentElement;
            item.remove();

            // Vaciar el contenedor del resumen con mensaje
            contenedorResumen.innerHTML = `<p class="text-gray-600 col-span-3">No hay productos en el carrito.</p>`;
        }

        // Asignar eventos
        btnIncrease.addEventListener("click", increase);
        btnDecrease.addEventListener("click", decrease);
        btnQuitar.addEventListener("click", quitarProducto);

        // Inicializar precios al cargar
        updatePrecios();


    </script>
      

</Layout>