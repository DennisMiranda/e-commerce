---
export const prerender = false;
import Layout from "../layouts/Welcome.astro";
---

<Layout>
  <div class="flex items-center justify-center md:h-screen md:mt-20 bg-white">
    <div class="w-full max-w-xs">
      <form
        class="bg-white shadow-lg rounded px-8 pt-6 pb-8 mb-4"
        id="login-form"
      >
        <div class="mb-4 text-center">
          <div class="text-4xl mb-6">🎀</div>
          <h2 class="text-xl font-semibold">Iniciar Sesión</h2>
        </div>
        <input
          class="shadow appearance-none border-gray-150 rounded w-full py-2 px-3 text-gray-700
		  mb-4 leading-tight"
          type="email"
          placeholder="Email"
          id="email"
          required
        />
        <input
          class="shadow appearance-none border-gray-150 rounded w-full py-2 px-3 text-gray-700
		mb-4 leading-tight"
          type="password"
          placeholder="Contraseña"
          id="password"
          required
        />

        <button
          type="submit"
          class="bg-gray-400 text-white w-full py-2 px-4 rounded hover:bg-gray-500"
        >
          Ingresar
        </button>

        <p class="text-center text-xs mt-4 text-gray-600">
          <a href="#">¿Ovidaste tu contraseña?</a>
        </p>
      </form>

      <script>
        const form = document.getElementById("login-form") as HTMLFormElement;

        if (form) {
          form.addEventListener("submit", async (e) => {
            e.preventDefault();

            const email = (document.getElementById("email") as HTMLInputElement)
              .value;
            const password = (
              document.getElementById("password") as HTMLInputElement
            ).value;

            const res = await fetch(
              "http://localhost:3000/api/auth/admin/login",
              {
                method: "POST",
                credentials: "include", // 🔥 IMPORTANTE: permite cookies cross-origin
                headers: { "content-Type": "application/json" },
                body: JSON.stringify({ email, password }),
              }
            );

            const data = await res.json();

            if (data.token) {
              // Guardar el usuario en el localStorage
              window.localStorage.setItem("user", JSON.stringify(data.user));

              alert("Bienvenido!");
              window.location.href = "/";
            } else {
              alert(data.error || "Error al iniciar sesion");
            }
          });
        }
      </script>
    </div>
  </div>
</Layout>
