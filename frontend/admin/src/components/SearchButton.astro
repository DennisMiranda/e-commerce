---
import { Icon } from "astro-icon/components";
---

<!-- Search  button -->
<div class="flex flex-1 gap-2.5">
  <input
    type="text"
    placeholder="Buscar productos..."
    class="flex-1 px-4 py-2 border border-[var(--color-aside-bg)] rounded-md focus:outline-none focus:ring-2 focus:ring-[var(--color-aside-bg)]"
  />
  <button
    class="min-w-10 bg-[var(--color-aside-bg)] text-[var(--color-text-primary)] px-4 py-2 rounded-md hover:bg-[var(--color-text-primary)] hover:text-white text-xl"
  >
    <Icon name="search" />
  </button>
</div>
