---
const { title = "Registrar Producto" } = Astro.props;
export let isOpen = false;
export let mode = "add";
export let product = null;
---

<div
  id="modal-form"
  data-mode="add"
  style="display:none;"
  aria-labelledby="modal-add-product"
  role="dialog"
  aria-modal="true"
>
  <div
    class="fixed inset-0 bg-gray-500/75 transition-opacity"
    aria-hidden="true"
  >
  </div>

  <div
    id="modal-scroll-container"
    class="fixed inset-0 z-10 w-screen overflow-y-auto"
  >
    <div
      class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0"
    >
      <div
        class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg"
      >
        <div class="bg-white p-4">
          <div class="sm:flex sm:items-start">
            <div class="w-full mt-3 text-center sm:mt-0 sm:ml-2 sm:text-left">
              <h3
                class="text-2xl font-bold text-text-primary-hover"
                id="modal-title"
              >
                {title}
              </h3>
              <div class="w-full mt-2 text-sm text-text-primary">
                <slot />
              </div>
            </div>
          </div>
        </div>

        <!-- Botones abajo del modal -->
        <div class="px-4 pb-3 sm:flex sm:flex-row-reverse sm:px-6">
          <button
            id="add"
            type="button"
            class="cursor-pointer inline-flex w-full justify-center rounded-md bg-text-primary px-2 py-2 text-sm font-semibold text-white shadow-xs hover:bg-text-primary-hover sm:ml-3 sm:w-auto"
            >Guardar</button
          >
          <button
            id="cancel"
            type="button"
            class="cursor-pointer inline-flex w-full justify-center rounded-md bg-white px-2 py-2 text-sm font-semibold text-text-primary ring-1 shadow-xs ring-text-primary ring-inset hover:bg-gray-50 sm:mt-0 sm:w-auto"
            >Cancelar</button
          >
        </div>
      </div>
    </div>
  </div>
</div>

<script type="module">
  const modalID = "modal-form";
  const cancelBtnID = "cancel";
  const submitBtnID = "add";

  const modal = document.getElementById(modalID);
  const cancelBtn = document.getElementById(cancelBtnID);
  const submitBtn = document.getElementById(submitBtnID);
  const form = modal.querySelector("form");

  // Detectar modo actual
  const getMode = () => modal.dataset.mode || "add";
  const getProductId = () => modal.dataset.id || "";

  // Cancelar -> cerrar modal y limpiar campos
  cancelBtn.addEventListener("click", () => {
    modal.style.display = "none";
    form.reset();
    modal.dataset.mode = "add";
    modal.dataset.id = "";

    // Mostrar campo estatus de nuevo
    const statusField = form.querySelector('[name="product-status"]');
    if (statusField) {
      statusField.closest(".mb-4").style.display = "block";
    }
  });

  // Agregar -> validar, enviar y cerrar si todo está bien
  submitBtn.addEventListener("click", async () => {
    const requiredFields = form.querySelectorAll(
      "input[required], select[required]"
    );
    let isValid = true;

    // Validación de campos requeridos
    requiredFields.forEach((field) => {
      if (!field.value) {
        field.classList.add("border-red-500");
        isValid = false;
      } else {
        field.classList.remove("border-red-500");
      }
    });

    if (!isValid) {
      alert("Por favor completa todos los campos obligatorios.");
      return;
    }

    // Crear FormData
    const formData = new FormData(form);
    const mode = getMode();
    const productId = getProductId();

    const url =
      mode === "edit"
        ? `http://localhost:3000/products/${productId}`
        : "http://localhost:3000/products";

    const method = mode === "edit" ? "PUT" : "POST"; // Método de la petición

    const body = formData.entries().reduce((acc, [key, value]) => {
      acc[key] = value;
      return acc;
    }, {});

    try {
      // Enviar al backend el form data
      const response = await fetch(url, {
        method,
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(body),
        // body: formData, //Enviar formData
      });

      const result = await response.json();

      if (result.success) {
        // Si estamos en modo "editar", actualizamos la imagen
        if (formData.has("product-image")) {
          // Enviar la imagen por separado si se cambió
          const responseImage = await fetch(
            `http://localhost:3000/products/${result.data.id}/image`,
            {
              method: "POST", //Se podria poner:POST
              body: formData,
            }
          );

          const resultImage = await responseImage.json();
        }

        // Mensaje exitoso
        alert(
          mode === "edit"
            ? "Producto actualizado correctamente."
            : "Producto agregado correctamente."
        );
        modal.style.display = "none";
        form.reset(); // Limpiar el formulario

        //Actualizar la tabla
        const rowData = window?.gridApi?.getGridOption("rowData");
        if (mode === "edit") {
          // Reemplazar producto actualizado
          const index = rowData.findIndex((p) => p.id === result.data.id);
          if (index !== -1) {
            rowData[index] = result.data;
          }
        } else {
          // Agregar nuevo producto
          rowData.push(result.data);
        }

        window?.gridApi?.setGridOption("rowData", rowData);
        modal.dataset.mode = "add"; // Reset modo
        modal.dataset.id = "";
      } else {
        alert("Error: " + result.message);
      }
    } catch (error) {
      console.error("Error al enviar producto:", error);
      alert("Ocurrió un error al registrar el producto.");
    }
  });
</script>
