---
let actualState = 1;
---

<form
  id="productForm"
  enctype="multipart/form-data"
  class="bg-white w-full rounded p-6 flex flex-col"
>
  <!--Category -->
  <div class="mb-4 w-full flex flex-col">
    <label
      class="text-left block text-gray-700 text-sm font-bold mb-2"
      for="category"
    >
      Categoría:
    </label>
    <select
      name="select-category"
      id="category"
      class="flex-1 shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
    >
      <option value="">Selecciona una categoría</option>
      <option value="Skincare">Skincare</option>
      <option value="Maquillaje">Maquillaje</option>
      <option value="Cuidado Personal">Cuidado Personal</option>
      <option value="Accesorios">Accesorios</option>
    </select>
  </div>

  <!--Product Name -->
  <div class="mb-4 w-full flex flex-col">
    <label
      class="text-left block text-gray-700 text-sm font-bold mb-2"
      for="product-name"
    >
      Nombre:
    </label>
    <input
      class="flex-1 shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
      id="product-name"
      type="text"
      name="product-name"
      required
    />
  </div>

  <!--Product Brand -->
  <div class="mb-4 w-full flex flex-col">
    <label
      class="text-left block text-gray-700 text-sm font-bold mb-2"
      for="product-brand"
    >
      Marca:
    </label>
    <input
      class="flex-1 shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
      id="product-brand"
      type="text"
      name="product-brand"
      required
    />
  </div>

  <!--Product Description -->
  <div class="mb-4 w-full flex flex-col">
    <label
      class="text-left block text-gray-700 text-sm font-bold mb-2"
      for="product-description"
    >
      Descripción:
    </label>
    <input
      class="flex-1 shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
      id="product-description"
      type="text"
      name="product-description"
      required
    />
  </div>
  <!--Product status -->
  <div class="mb-4 w-full flex flex-col">
    <label
      class="text-left block text-gray-700 text-sm font-bold mb-2"
      for="product-status"
    >
      Estatus:
    </label>
    <div class="flex justify-center gap-4">
      <div>
        <input
          class="p-2"
          id="product-status"
          type="radio"
          name="product-status"
          value="0"
          checked={actualState === 0}
        />
        <span>Inactivo</span>
      </div>
      <div>
        <input
          class="p-2"
          id="product-status"
          type="radio"
          name="product-status"
          value="1"
          checked={actualState === 1}
        />
        <span> Activo</span>
      </div>
    </div>
  </div>
  <!--Product price -->
  <div class="mb-4 w-full flex flex-col">
    <label
      class="text-left block text-gray-700 text-sm font-bold mb-2"
      for="product-price"
    >
      Precio:
    </label>
    <input
      class="flex-1 shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
      id="product-price"
      type="number"
      name="product-price"
      required
    />
  </div>
  <!--Product quantity -->
  <div class="mb-4 w-full flex flex-col">
    <label
      class="text-left block text-gray-700 text-sm font-bold mb-2"
      for="product-stock"
    >
      Cantidad:
    </label>
    <input
      class="flex-1 shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
      id="product-stock"
      type="number"
      name="product-stock"
      required
    />
  </div>

  <!--Product image -->
  <div class="mb-4 w-full flex flex-col">
    <label
      class="text-left block text-gray-700 text-sm font-bold mb-2"
      for="product-image"
    >
      Imagen:
    </label>
    <input
      id="product-image"
      type="file"
      name="product-image"
      accept="image/*"
      class="mt-1 block w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-4
           file:rounded-full file:border-0 file:text-sm file:font-semibold
           file:bg-blue-50 file:text-gray-800 hover:file:bg-blue-100"
      required
    />
  </div>
</form>
